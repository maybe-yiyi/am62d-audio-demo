		lv2:index 7 ;
		lv2:symbol "in_ch7" ;
		lv2:name "Input Ch 7" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:OutputPort ;
		lv2:index 8 ;
		lv2:symbol "out_ch0" ;
		lv2:name "Output Ch 0"
	] , [
		a lv2:AudioPort, lv2:OutputPort ;
		lv2:index 9 ;
		lv2:symbol "out_ch1" ;
		lv2:name "Output Ch 1" ;
		lv2:portProperty lv2:connectionOptional
	] , [
