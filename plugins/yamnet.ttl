@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<urn:am62d:yamnet>
    a lv2:Plugin ;
    lv2:port [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 0 ;
        lv2:symbol "in_l" ;
        lv2:name "Input L"
    ] , [
        a lv2:AudioPort, lv2:InputPort ;
        lv2:index 1 ;
        lv2:symbol "in_r" ;
        lv2:name "Input R"
    ] , [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 2 ;
        lv2:symbol "out_l" ;
        lv2:name "Output L"
    ] , [
        a lv2:AudioPort, lv2:OutputPort ;
        lv2:index 3 ;
        lv2:symbol "out_r" ;
        lv2:name "Output R"
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 4 ;
        lv2:symbol "speech" ;
        lv2:name "Speech Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 5 ;
        lv2:symbol "alert" ;
        lv2:name "Alert Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 6 ;
        lv2:symbol "laughter" ;
        lv2:name "Laughter Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 7 ;
        lv2:symbol "crowd" ;
        lv2:name "Crowd Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 8 ;
        lv2:symbol "hvac" ;
        lv2:name "HVAC Noise Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 9 ;
        lv2:symbol "ext_noise" ;
        lv2:name "External Noise Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 10 ;
        lv2:symbol "door" ;
        lv2:name "Door Event Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 11 ;
        lv2:symbol "music" ;
        lv2:name "Music Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort, lv2:OutputPort ;
        lv2:index 12 ;
        lv2:symbol "typing" ;
        lv2:name "Typing Score" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] .
