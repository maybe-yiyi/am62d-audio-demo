@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<urn:am62d:downmix>
	a lv2:Plugin ;
	lv2:port [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 0 ;
		lv2:symbol "in_ch0" ;
		lv2:name "Input Ch 0"
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 1 ;
		lv2:symbol "in_ch1" ;
		lv2:name "Input Ch 1" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 2 ;
		lv2:symbol "in_ch2" ;
		lv2:name "Input Ch 2" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 3 ;
		lv2:symbol "in_ch3" ;
		lv2:name "Input Ch 3" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 4 ;
		lv2:symbol "in_ch4" ;
		lv2:name "Input Ch 4" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 5 ;
		lv2:symbol "in_ch5" ;
		lv2:name "Input Ch 5" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 6 ;
		lv2:symbol "in_ch6" ;
		lv2:name "Input Ch 6" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 7 ;
		lv2:symbol "in_ch7" ;
		lv2:name "Input Ch 7" ;
		lv2:portProperty lv2:connectionOptional
	] , [
		a lv2:AudioPort, lv2:OutputPort ;
		lv2:index 8 ;
		lv2:symbol "out" ;
		lv2:name "Output"
	] .
