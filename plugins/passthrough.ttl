@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<urn:am62d:passthrough>
	a lv2:Plugin ;
	lv2:port [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 0 ;
		lv2:symbol "in_l" ;
		lv2:name "Input L"
	] , [
		a lv2:AudioPort, lv2:OutputPort ;
		lv2:index 1 ;
		lv2:symbol "out_l" ;
		lv2:name "Output L"
	] , [
		a lv2:AudioPort, lv2:InputPort ;
		lv2:index 2 ;
		lv2:symbol "in_r" ;
		lv2:name "Input R"
	] , [
		a lv2:AudioPort, lv2:OutputPort ;
		lv2:index 3 ;
		lv2:symbol "out_r" ;
		lv2:name "Output R"
	] .
